{% extends 'base.html.twig' %}

{% block title %}
    {{ reference.title }} &middot; {{  parent() }}
{% endblock %}

{% block main %}
    <section class="bg-background-secondary">
        <div class="container mx-auto px-8 py-16 lg:py-24">
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <article class="bg-white rounded-2xl shadow-xl overflow-hidden">
                    {% if reference.imagePath %}
                        <img class="w-full" src="{{ reference.imagePath }}" alt="Foto zur Referenz „{{ reference.title }}"">
                    {% endif %}
                    <div class="p-8 lg:p-12">
                        <h2 class="text-4xl font-semibold text-brand-primary">
                            {{ reference.title }}
                        </h2>
                        <div class="mt-8 flex flex-col lg:flex-row lg:gap-0">
                            {# Mobile: single line with separators #}
                            <div class="lg:hidden text-brand-secondary text-xs leading-relaxed flex flex-wrap items-center gap-x-1.5 mb-6">
                                <span class="font-semibold">{{ reference.createdAt | format_datetime('none', 'none', pattern='MMMM yyyy', locale='de') }}</span>
                                {% if reference.category %}
                                    <span>&middot;</span>
                                    <span>{{ reference.category.name }}</span>
                                {% endif %}
                                {% if reference.printer or reference.materialLabel %}
                                    <span>&middot;</span>
                                    <span>
                                        {%- if reference.printer %}{{ reference.printer.value }}{% endif %}
                                        {%- if reference.printer and reference.materialLabel %}, {% endif %}
                                        {%- if reference.materialLabel %}{{ reference.materialLabel }}{% endif -%}
                                    </span>
                                {% endif %}
                                {% if reference.ratingUrl %}
                                    <span>&middot;</span>
                                    <a href="{{ reference.ratingUrl }}" target="_blank" rel="noopener noreferrer"
                                       class="hover:text-brand-primary transition-colors">Kundenbewertung lesen</a>
                                {% endif %}
                            </div>
                            {# Desktop: vertical sidebar #}
                            <div class="hidden lg:flex lg:flex-col text-brand-secondary lg:w-44 flex-shrink-0 lg:pr-8">
                                <p class="text-xs font-semibold leading-relaxed">{{ reference.createdAt | format_datetime('none', 'none', pattern='MMMM yyyy', locale='de') }}</p>
                                {% if reference.printer or reference.materialLabel %}
                                    <div class="mt-3 text-xs leading-relaxed">
                                        <p class="font-semibold">Druckdaten</p>
                                        {% if reference.printer %}
                                            <p>{{ reference.printer.value }}</p>
                                        {% endif %}
                                        {% if reference.materialLabel %}
                                            <p>{{ reference.materialLabel }}</p>
                                        {% endif %}
                                    </div>
                                {% endif %}
                                {% if reference.ratingUrl %}
                                    <div class="mt-3 text-xs leading-relaxed">
                                        <p class="font-semibold">Weitere Infos</p>
                                        <a href="{{ reference.ratingUrl }}" target="_blank" rel="noopener noreferrer"
                                           class="hover:text-brand-primary transition-colors">
                                            Kundenbewertung lesen
                                        </a>
                                    </div>
                                {% endif %}
                                {% if reference.category %}
                                    <div class="mt-auto pt-3">
                                        <span class="bg-brand-primary/10 text-brand-primary rounded-full px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wide">{{ reference.category.name }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="hidden lg:block self-stretch border-l border-gray-100"></div>
                            <div class="mt-6 lg:mt-0 lg:pl-8 prose prose-orange prose-a:no-underline hover:prose-a:underline prose-a:text-brand-primary prose-a:font-normal max-w-none">
                                {{ reference.description | markdown_to_html }}
                            </div>
                        </div>
                    </div>
                    {% if reference.source %}
                        <div class="px-8 py-6 lg:px-12">
                            {% include '_model.html.twig' with { 'model': reference.source } %}
                        </div>
                    {% endif %}
                </article>
                <div class="mt-12">
                    <a href="{{ path('app_references') }}" class="border border-brand-secondary hover:border-brand-primary hover:text-brand-primary px-4 py-2 rounded-xl text-brand-secondary text-sm uppercase">&larr; Alle Referenzen</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
