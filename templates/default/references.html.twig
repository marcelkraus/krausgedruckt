{% extends 'base.html.twig' %}

{% block title %}
    Referenzen &middot; {{  parent() }}
{% endblock %}

{% block main %}
    <section class="bg-background-secondary">
        <div class="container mx-auto px-8 py-16 lg:py-24">
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <h2 class="mb-8 text-4xl font-semibold text-brand-primary lg:mb-12">
                    Meine Referenzen.<br/>
                    <span class="text-brand-secondary">Ein kleiner Einblick in meine bunte Welt.</span>
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    {% for reference in references %}
                        <article class="bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col">
                            {% if reference.imagePath %}
                                <a href="{{ path('app_reference_detail', {year: reference.year, slug: reference.slug}) }}">
                                    <img class="w-full h-64 object-cover" src="{{ reference.imagePath | imagine_filter('reference_thumb') }}" alt="{{ reference.title }}">
                                </a>
                            {% endif %}
                            <div class="p-6 flex flex-col flex-1">
                                <h3 class="text-xl font-semibold text-brand-primary">
                                    <a href="{{ path('app_reference_detail', {year: reference.year, slug: reference.slug}) }}" class="hover:underline">{{ reference.title }}</a>
                                </h3>
                                {% if reference.summary %}
                                    <p class="mt-2 text-brand-secondary line-clamp-3">{{ reference.summary }}</p>
                                {% endif %}
                                <div class="mt-auto pt-4 flex items-center justify-between">
                                    <span class="text-brand-secondary font-semibold text-sm">{{ reference.createdAt | date('d.m.Y') }}</span>
                                    {% if reference.category %}
                                        <span class="bg-brand-primary/10 text-brand-primary rounded-full px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wide">{{ reference.category.name }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
